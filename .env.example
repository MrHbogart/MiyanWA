# MiyanWA production environment template
# Copy to `.env` on the VPS and replace the placeholder secret before starting.

# Mirror and image settings
# Leave these empty to use the default upstream registries.
PYTHON_BASE_IMAGE=python:3.12-slim
NODE_BASE_IMAGE=node:20-alpine

DEBIAN_MIRROR=
DEBIAN_SECURITY_MIRROR=
APT_DISABLE_VALID_UNTIL=true
ALPINE_MAIN_MIRROR=
ALPINE_COMMUNITY_MIRROR=

PIP_INDEX_URL=https://pypi.org/simple
PIP_EXTRA_INDEX_URL=
PIP_TRUSTED_HOSTS=
NPM_REGISTRY=https://registry.npmjs.org/

# Public domain
APP_DOMAIN=miyangroup.com
APP_WWW_DOMAIN=www.miyangroup.com
APP_SCHEME=https

# Published host ports for reverse proxying from VPS nginx
BACKEND_HOST_PORT=8000
FRONTEND_HOST_PORT=3000

# Backend (Django)
DJANGO_SECRET_KEY=change-me-to-a-long-random-production-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=miyangroup.com,www.miyangroup.com,localhost,127.0.0.1,backend
DJANGO_LOG_LEVEL=INFO

# Database
DJANGO_DB_NAME=db.sqlite3
DB_WAIT_TIMEOUT=120
DB_WAIT_INTERVAL=3

# Docker platform override (leave empty for host-native architecture)
# Set to linux/amd64 or linux/arm64 if you need to force one platform.
DOCKER_PLATFORM=

# CORS/CSRF
DJANGO_CORS_ALLOWED_ORIGINS=https://miyangroup.com,https://www.miyangroup.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://miyangroup.com,https://www.miyangroup.com
DJANGO_SESSION_COOKIE_NAME=miyan_sessionid
DJANGO_CSRF_COOKIE_NAME=miyan_csrftoken

# Reverse-proxy and cookie security for production HTTPS
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_TRUST_PROXY_HEADERS=True
DJANGO_USE_X_FORWARDED_HOST=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True

# Throttling
DRF_USER_THROTTLE_RATE=1000/hour
DRF_ANON_THROTTLE_RATE=100/hour

# Observability
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Build metadata
APP_VERSION=0.1.0
APP_COMMIT_SHA=local

# Frontend (Nuxt)
NODE_ENV=production
NUXT_PUBLIC_API_BASE_URL=https://miyangroup.com/api
NUXT_PUBLIC_SITE_DOMAIN=https://miyangroup.com
